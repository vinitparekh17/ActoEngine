<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
  <PropertyGroup>
    <DeleteExistingFiles>false</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishProvider>FileSystem</PublishProvider>
    <PublishUrl>Z:\ActoEngine</PublishUrl>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <_TargetId>Folder</_TargetId>

    <!-- Frontend publish settings -->
    <FrontendSourceDir>$(MSBuildProjectDirectory)\..\Frontend</FrontendSourceDir>
    <FrontendPublishDir>Z:\ActoEngine_Client</FrontendPublishDir>
  </PropertyGroup>

  <!--
    Runs only when this profile is used (VS Publish / `dotnet publish /p:PublishProfile=FolderProfile`).
    Builds the frontend inside Docker on this dev machine (no Node required on host),
    exports dist/, then mirrors dist/ + server.py to the server share at Z:\ActoEngine_Client.

    The SPA server itself (python server.py) runs on the SERVER PC as a scheduled task —
    see docs/Run_frontend.md for one-time setup. No restart is needed after republish
    because SimpleHTTPRequestHandler re-reads files on every request.
  -->
  <Target Name="PublishFrontendAfterBackend" AfterTargets="Publish">
    <Message Importance="high" Text="==> [Frontend] Building dist via Docker (Dockerfile.Builder)..." />
    <Exec Command="docker build -f Dockerfile.Builder -o dist ."
          WorkingDirectory="$(FrontendSourceDir)" />

    <MakeDir Directories="$(FrontendPublishDir)" />

    <Message Importance="high" Text="==> [Frontend] Mirroring dist to $(FrontendPublishDir)\dist ..." />
    <!-- robocopy returns 0-7 on success; IgnoreExitCode prevents MSBuild from failing. -->
    <Exec Command="robocopy &quot;$(FrontendSourceDir)\dist&quot; &quot;$(FrontendPublishDir)\dist&quot; /MIR /NFL /NDL /NJH /NJS /NC /NS /NP"
          IgnoreExitCode="true" />

    <Message Importance="high" Text="==> [Frontend] Copying server.py ..." />
    <Copy SourceFiles="$(FrontendSourceDir)\server.py"
          DestinationFolder="$(FrontendPublishDir)"
          OverwriteReadOnlyFiles="true" />

    <Message Importance="high" Text="==> [Frontend] Done. Backend -> $(PublishUrl) | Frontend -> $(FrontendPublishDir)" />
  </Target>
</Project>
